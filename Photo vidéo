    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; height: 68px; display: flex; align-items: center; padding: 0 4%; gap: 1.5rem; background: rgba(20,20,20,.97); border-bottom: 1px solid rgba(255,255,255,.06); }
